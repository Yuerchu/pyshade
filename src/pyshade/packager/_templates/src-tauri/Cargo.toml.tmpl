# generated by pyshade init (pyshade {{pyshade_version}})
[package]
name = "{{crate_name}}"
version = "{{version}}"
edition = "2021"

[lib]
# _lib 后缀:Windows 上 cargo bin/lib 同名冲突(rust-lang/cargo#8519)
name = "{{lib_name}}"
crate-type = ["staticlib", "cdylib", "rlib"]

[[bin]]
name = "{{crate_name}}"
path = "src/main.rs"
required-features = ["pytauri/standalone"]

[build-dependencies]
tauri-build = "2"

[dependencies]
tauri = "2.8"
pyo3 = "0.25"
pytauri = "0.8"
# 必须直接依赖:capability 的 pytauri:default 权限经 cargo links metadata
# 只向直接依赖方暴露,tauri-build 才能发现它
tauri-plugin-pytauri = "0.8"

# 独立 profile:tauri-cli 会把 bundle.resources 拷到可执行文件同目录,
# 与 release/debug 隔离防污染(tauri dev 误链复制出的 Python 环境)
[profile.bundle-dev]
inherits = "dev"

[profile.bundle-release]
inherits = "release"
